{{- if or (eq .chezmoi.os "linux") (eq .chezmoi.os "darwin") (eq .chezmoi.os "windows") -}}
#!/bin/bash

# ============================================
# Oh My OpenAgent 安装脚本（chezmoi run_once_）
# 依赖：OpenCode 已安装
# 支持 Linux（含 WSL/多发行版）、macOS、Windows
# 参考: https://github.com/code-yeongyu/oh-my-openagent
# 命名：opencode-omo 确保在 install-opencode 之后执行（字母序）
# 安装方式：
#   1. opencode plugin oh-my-openagent -g  → 注册到 opencode.json
#   2. npm install --ignore-scripts          → 下载插件模块到 node_modules
# （oh-my-opencode 已重命名为 oh-my-openagent，旧名仍兼容）
# ============================================

# 获取 common_install.sh 路径
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="${CHEZMOI_PROJECT_ROOT:-$(cd "${SCRIPT_DIR}/../.." && pwd 2>/dev/null || echo "$HOME")}"
COMMON_INSTALL="${PROJECT_ROOT}/scripts/chezmoi/common_install.sh"

if [ ! -f "$COMMON_INSTALL" ]; then
    COMMON_INSTALL="$HOME/.local/share/chezmoi/scripts/chezmoi/common_install.sh"
fi

if [ -f "$COMMON_INSTALL" ]; then
    source "$COMMON_INSTALL"
else
    function setup_proxy() { :; }
    function detect_os_and_package_manager() { :; }
fi

# 设置代理
setup_proxy "${PROXY:-{{ env "http_proxy" | default "http://127.0.0.1:7890" }}}"

# 检测操作系统（用于日志）
detect_os_and_package_manager 2>/dev/null || true
PLATFORM="${PLATFORM:-unknown}"

# 前置：OpenCode 必须已安装
if ! command -v opencode &> /dev/null; then
    echo "[WARNING] OpenCode 未安装，跳过 Oh My OpenAgent。请先执行 run_once_install-opencode 或手动安装 OpenCode。"
    exit 0
fi

# 已安装检查：opencode.json 含插件注册 + node_modules 中有插件模块
OC_JSON="${HOME}/.config/opencode/opencode.json"
OC_NODE_MODULES="${HOME}/.config/opencode/node_modules"
OMO_MODULE="${OC_NODE_MODULES}/oh-my-openagent"
OMO_LEGACY_MODULE="${OC_NODE_MODULES}/oh-my-opencode"

if [[ -f "$OC_JSON" ]] && grep -qE '"oh-my-openagent"|"oh-my-opencode"' "$OC_JSON" 2>/dev/null; then
    if [[ -d "$OMO_MODULE" ]] || [[ -d "$OMO_LEGACY_MODULE" ]]; then
        PLUGIN_NAME="$(grep -oE '"oh-my-openagent"|"oh-my-opencode"' "$OC_JSON" 2>/dev/null | head -n1)"
        echo "[INFO] Oh My OpenAgent 已配置（plugin 已含 ${PLUGIN_NAME}，模块已就位）"
        exit 0
    fi
fi

echo "[INFO] 开始安装 Oh My OpenAgent..."

# 步骤1：用 opencode plugin 注册插件到 opencode.json
if ! opencode plugin oh-my-openagent -g 2>/dev/null; then
    echo "[WARNING] opencode plugin 命令失败，手动写入 opencode.json..."
    if [[ -f "$OC_JSON" ]]; then
        if ! grep -q '"oh-my-openagent"' "$OC_JSON" 2>/dev/null; then
            # 用 jq 或简单 sed 插入插件名（兼容处理）
            echo '{"plugin":["oh-my-openagent"]}' > "$OC_JSON"
        fi
    else
        mkdir -p "$(dirname "$OC_JSON")"
        echo '{"plugin":["oh-my-openagent"]}' > "$OC_JSON"
    fi
fi

# 步骤2：安装插件 npm 模块（--ignore-scripts 绕过 Node v22 兼容问题）
if [[ -d "$OMO_MODULE" ]]; then
    echo "[INFO] oh-my-openagent 模块已存在，跳过 npm install"
else
    echo "[INFO] 正在安装 oh-my-openagent 插件模块..."
    cd "${HOME}/.config/opencode" || exit 0

    # 优先用 bun（更快），其次 npm，最后 npx
    if command -v bun &>/dev/null; then
        bun install oh-my-openagent@latest --ignore-scripts 2>/dev/null || true
    fi

    if [[ ! -d "$OMO_MODULE" ]]; then
        npm install oh-my-openagent@latest --ignore-scripts --save 2>/dev/null || true
    fi

    cd - > /dev/null || true
fi

# 最终验证
if [[ -d "$OMO_MODULE" ]] && [[ -f "$OC_JSON" ]] && grep -qE '"oh-my-openagent"|"oh-my-opencode"' "$OC_JSON" 2>/dev/null; then
    echo "[SUCCESS] Oh My OpenAgent 已安装（插件已注册，模块 v$(node -e "console.log(require('${OMO_MODULE}/package.json').version)" 2>/dev/null || echo '?') 已就位）"
    echo "[INFO] 重启 OpenCode 后生效。配置目录: ${HOME}/.config/opencode/oh-my-opencode/"
else
    echo "[WARNING] Oh My OpenAgent 安装可能不完整"
    echo "[INFO] 手动安装: opencode plugin oh-my-openagent -g && npm install oh-my-openagent@latest --ignore-scripts"
fi
{{- end -}}
