{{- if eq .chezmoi.os "windows" -}}
# rmux 配置文件（Windows）
# 对齐 dot_tmux.conf.tmpl 的可移植部分；手动启动 rmux（WT 仍默认 Git Bash）
# 说明与排错: docs/RMUX_WINDOWS.md
#
# 不迁移（rmux 不支持或无等价物）:
#   TPM / @plugin / run '~/.tmux/plugins/...'
#   @catppuccin_* / run catppuccin.tmux
#   resurrect / continuum / run-shell
#   MouseDrag1Status swap-window（支持未验证）

# ============================================
# 基础配置（对齐 dot_tmux.conf.tmpl）
# ============================================

unbind C-b
set-option -g prefix C-b
bind-key C-b send-prefix

bind r source-file ~/.rmux.conf \; display "Config reloaded!"

set -g base-index 1
setw -g pane-base-index 1
set -g mouse on
set -g history-limit 50000
set -g display-time 4000
set -s escape-time 50
setw -g automatic-rename on
set -g renumber-windows on

set -g default-terminal "xterm-256color"
set -g default-shell "{{ .windows_git_bash_path }}"

# ============================================
# 状态栏（Catppuccin Mocha 静态复刻，对齐 dot_tmux.conf.tmpl）
# ============================================

set -g status on
set -g status-interval 1
set -g status-position top
set -g status-style "fg=#cdd6f4,bg=#181825"
set -g status-left-length 100
set -g status-right-length 100
set -g status-left '#[fg=#11111b,bg=#a6e3a1] #S #[fg=#a6e3a1,bg=#181825] '
set -g status-right ""

set -g window-status-format '#[fg=#181825,bg=#313244] #[fg=#cdd6f4,bg=#313244] #W #[fg=#181825,bg=#313244] '
set -g window-status-current-format '#[fg=#181825,bg=#cba6f7] #[fg=#1e1e2e,bg=#cba6f7] #W* #[fg=#cba6f7,bg=#181825] '

set -g pane-border-style "fg=#45475a"
set -g pane-active-border-style "fg=#cba6f7"

# ============================================
# 窗口和面板管理（对齐 dot_tmux.conf.tmpl）
# ============================================

bind '"' split-window -v -c "#{pane_current_path}"
bind %  split-window -h -c "#{pane_current_path}"

bind -r i select-pane -U
bind -r k select-pane -D
bind -r j select-pane -L
bind -r l select-pane -R
unbind h

unbind -n C-Up
unbind -n C-Down
unbind -n C-Left
unbind -n C-Right
bind -r -n C-Up    resize-pane -U 3
bind -r -n C-Down  resize-pane -D 3
bind -r -n C-Left  resize-pane -L 3
bind -r -n C-Right resize-pane -R 3
unbind H
unbind J
unbind K
unbind L
unbind I
unbind C-Up
unbind C-Down
unbind C-Left
unbind C-Right

bind -r z resize-pane -Z
bind   = select-layout -E

bind -r C-h select-window -t :-
bind -r C-l select-window -t :+

bind c new-window
bind , rename-window
bind p previous-window
bind n next-window
bind d detach-client

# ============================================
# 复制模式（rmux 原生 copy-command，替代 tmux-yank）
# ============================================

setw -g mode-keys vi
set -s copy-command 'clip.exe'
bind [ copy-mode
bind -T copy-mode-vi v send-keys -X begin-selection
bind -T copy-mode-vi C-v send-keys -X rectangle-toggle
bind -T copy-mode-vi y send-keys -X copy-pipe-and-cancel
{{- end -}}
