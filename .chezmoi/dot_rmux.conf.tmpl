{{- if eq .chezmoi.os "windows" -}}
# rmux 配置文件（Windows）
# 由 dot_tmux.conf 精简：无 TPM/插件/run-shell；手动启动 rmux（WT 仍默认 Git Bash）
# 说明与排错: docs/RMUX_WINDOWS.md

# ============================================
# 基础选项
# ============================================
set -g mouse on
set -g base-index 1
set -g pane-base-index 1
set -g history-limit 50000
set -g display-time 4000
set -s escape-time 50

set -g default-terminal "xterm-256color"
set -g default-shell "{{ .windows_git_bash_path }}"

# ============================================
# 状态栏（Catppuccin Mocha 静态配色，对齐 Windows Terminal）
# ============================================
set -g status on
set -g status-interval 1
set -g status-style "fg=#cdd6f4,bg=#1e1e2e"
set -g status-left "[#S] "
set -g status-right "#H %Y-%m-%d %H:%M"
set -g status-left-length 32
set -g status-right-length 64

set -g window-status-style "fg=#888888"
set -g window-status-current-style "fg=#1e1e2e,bg=#89b4fa"

set -g pane-border-style "fg=#45475a"
set -g pane-active-border-style "fg=#89b4fa"

# ============================================
# 前缀与按键（贴近 tmux 习惯）
# ============================================
unbind-key C-b
bind-key C-b send-prefix

bind-key r source-file ~/.rmux.conf

# 分屏（与 tmux 一致，并保留 % / " 别名）
bind-key | split-window -h
bind-key - split-window -v
bind-key % split-window -h
bind-key '"' split-window -v

# 切换窗格（hjkl）
bind-key h select-pane -L
bind-key j select-pane -D
bind-key k select-pane -U
bind-key l select-pane -R

# 调整窗格大小（前缀 + H/J/K/L，可重复）
bind-key -r H resize-pane -L 5
bind-key -r J resize-pane -D 5
bind-key -r K resize-pane -U 5
bind-key -r L resize-pane -R 5

# 窗口
bind-key c new-window
bind-key , rename-window
bind-key p previous-window
bind-key n next-window
bind-key -r C-h select-window -t :-
bind-key -r C-l select-window -t :+

# 分离会话
bind-key d detach-client
{{- end -}}
