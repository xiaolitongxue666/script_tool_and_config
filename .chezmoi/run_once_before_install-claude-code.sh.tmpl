{{- if or (eq .chezmoi.os "linux") (eq .chezmoi.os "darwin") (eq .chezmoi.os "windows") -}}
{{/* chezmoi:template:line-endings=lf — 与 run_after_claude-code-settings 一致，避免 Windows 下无意义 diff */}}
#!/usr/bin/env bash

# ============================================
# Claude Code 安装（chezmoi run_once_before_）
# 必须在 modify ~/.claude/settings.json 之前执行，确保 node/npm 可用
# 参考: npm install -g @anthropic-ai/claude-code
# ============================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="${CHEZMOI_PROJECT_ROOT:-$(cd "${SCRIPT_DIR}/../.." && pwd 2>/dev/null || echo "$HOME")}"
COMMON_INSTALL="${PROJECT_ROOT}/scripts/chezmoi/common_install.sh"

if [[ ! -f "$COMMON_INSTALL" ]]; then
    COMMON_INSTALL="$HOME/.local/share/chezmoi/scripts/chezmoi/common_install.sh"
fi

if [[ -f "$COMMON_INSTALL" ]]; then
    # shellcheck disable=SC1090
    source "$COMMON_INSTALL"
else
    echo "[WARNING] 未找到 common_install.sh，使用基本函数"
    function setup_proxy() { :; }
    function detect_os_and_package_manager() {
        OS="$(uname -s)"
        if [[ "$OS" == "Darwin" ]]; then
            PLATFORM="macos"
            PACKAGE_MANAGER="brew"
        elif [[ "$OS" == "Linux" ]]; then
            PLATFORM="linux"
            if command -v pacman &> /dev/null; then
                PACKAGE_MANAGER="pacman"
            elif command -v apt-get &> /dev/null; then
                PACKAGE_MANAGER="apt"
            elif command -v dnf &> /dev/null; then
                PACKAGE_MANAGER="dnf"
            elif command -v yum &> /dev/null; then
                PACKAGE_MANAGER="yum"
            fi
        elif [[ "$OS" =~ ^(MINGW|MSYS|CYGWIN) ]]; then
            PLATFORM="windows"
            if command -v winget &> /dev/null; then
                PACKAGE_MANAGER="winget"
            elif command -v pacman.exe &> /dev/null; then
                PACKAGE_MANAGER="pacman"
            fi
        fi
    }
fi

setup_proxy "${PROXY:-{{ env "http_proxy" | default "http://127.0.0.1:7890" }}}"

detect_os_and_package_manager || exit 1

IS_WSL=0
if [[ "${PLATFORM:-}" == "linux" ]]; then
    if grep -qEi "Microsoft|WSL" /proc/version 2>/dev/null || [[ -n "${WSL_DISTRO_NAME:-}" ]]; then
        IS_WSL=1
    fi
fi

if [[ "${PLATFORM:-}" == "darwin" ]]; then
    echo "[INFO] 环境: macOS (brew)"
elif [[ "${PLATFORM:-}" == "windows" ]]; then
    echo "[INFO] 环境: Windows (${PACKAGE_MANAGER:-unknown})"
elif [[ "${PLATFORM:-}" == "linux" ]]; then
    if [[ "$IS_WSL" -eq 1 ]]; then
        echo "[INFO] 环境: Linux (WSL, ${PACKAGE_MANAGER:-unknown})"
    else
        echo "[INFO] 环境: Linux (原生, ${PACKAGE_MANAGER:-unknown})"
    fi
fi

# fnm / node 常见安装路径（run_once_00 可能尚未写入当前 shell 的 PATH）
export PATH="${HOME}/.local/share/fnm:${HOME}/.local/bin:${PATH}"

if command -v fnm &>/dev/null; then
    eval "$(fnm env 2>/dev/null)" || true
fi

if command -v claude &>/dev/null; then
    if claude --version &>/dev/null; then
        echo "[INFO] Claude Code 已安装: $(claude --version 2>/dev/null | head -n1)"
        exit 0
    fi
fi

if ! command -v fnm &>/dev/null; then
    echo "[ERROR] 未找到 fnm。请先成功执行 run_once_00-install-version-managers.sh（安装 fnm）后再 apply。"
    exit 1
fi

if ! command -v node &>/dev/null; then
    echo "[INFO] 未检测到 node，使用 fnm 安装 Node.js LTS..."
    if ! fnm install lts/* 2>&1; then
        echo "[ERROR] fnm 安装 Node.js 失败，请检查网络或代理后重试。"
        exit 1
    fi
    eval "$(fnm env 2>/dev/null)" || true
    if ! fnm use lts/* 2>/dev/null; then
        fnm use default 2>/dev/null || true
    fi
    hash -r 2>/dev/null || true
fi

if ! command -v node &>/dev/null; then
    echo "[ERROR] node 仍不可用，请检查 fnm 与 PATH。"
    exit 1
fi

if ! command -v npm &>/dev/null; then
    echo "[ERROR] npm 不可用（node 已安装但缺少 npm），请检查 Node 安装。"
    exit 1
fi

echo "[INFO] 开始全局安装 @anthropic-ai/claude-code..."
if npm install -g @anthropic-ai/claude-code; then
    hash -r 2>/dev/null || true
    if command -v claude &>/dev/null && claude --version &>/dev/null; then
        echo "[SUCCESS] Claude Code 可用: $(claude --version 2>/dev/null | head -n1)"
    else
        echo "[WARNING] npm 安装完成但 claude 命令不可用，请检查 PATH 或手动执行: npm install -g @anthropic-ai/claude-code"
    fi
else
    echo "[WARNING] npm 全局安装 claude-code 失败，请手动执行: npm install -g @anthropic-ai/claude-code"
fi

exit 0
{{- end -}}
