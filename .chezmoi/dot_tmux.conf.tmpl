{{- if or (eq .chezmoi.os "linux") (eq .chezmoi.os "darwin") -}}
# Tmux 统一配置文件
# 配置文件位置: ~/.config/tmux/tmux.conf 或 ~/.tmux.conf
# 使用 Catppuccin Mocha 主题

# ============================================
# 基础配置
# ============================================

# 设置前缀键为 Ctrl+b
unbind C-b
set-option -g prefix C-b
bind-key C-b send-prefix

# 重新加载配置文件
bind r source-file ~/.tmux.conf \; display "配置文件已重新加载！"

# 设置窗口和面板索引从 1 开始
set -g base-index 1
setw -g pane-base-index 1

# 启用鼠标支持
set -g mouse on

# 滚动历史记录
set -g history-limit 50000

# 显示消息时间（毫秒）
set -g display-time 4000

# 降低转义时间，提高响应速度（从 500ms 到 50ms）
set -s escape-time 50

# ============================================
# 窗口和面板管理
# ============================================

# 分屏（tmux 默认键 + 保持当前目录）
bind '"' split-window -v -c "#{pane_current_path}"
bind %  split-window -h -c "#{pane_current_path}"

# 面板切换（对齐 nvim <leader> i/k/j/l：上/下/左/右）
bind -r i select-pane -U
bind -r k select-pane -D
bind -r j select-pane -L
bind -r l select-pane -R
unbind h

# 调整面板大小（对齐 nvim Ctrl+方向键，3 格，无需 Prefix）
unbind -n C-Up
unbind -n C-Down
unbind -n C-Left
unbind -n C-Right
bind -r -n C-Up    resize-pane -U 3
bind -r -n C-Down  resize-pane -D 3
bind -r -n C-Left  resize-pane -L 3
bind -r -n C-Right resize-pane -R 3
unbind H
unbind J
unbind K
unbind L
unbind I
unbind C-Up
unbind C-Down
unbind C-Left
unbind C-Right

# 布局（对标 nvim leader+wb / leader+wm）
bind -r z resize-pane -Z
bind   = select-layout -E

# 窗口切换
bind -r C-h select-window -t :-
bind -r C-l select-window -t :+

# 设置窗口和面板重命名
setw -g automatic-rename on
set -g renumber-windows on

# 拖拽重新排序窗口
bind-key -n MouseDrag1Status swap-window -t=

# ============================================
# 终端和颜色配置
# ============================================

# 默认 shell：run-shell 动态检测 zsh（macOS Homebrew / 系统路径）
run-shell 'ZSH_PATH=""; if [ -f /opt/homebrew/bin/zsh ]; then ZSH_PATH="/opt/homebrew/bin/zsh"; elif [ -f /usr/local/bin/zsh ]; then ZSH_PATH="/usr/local/bin/zsh"; elif [ -f /usr/bin/zsh ]; then ZSH_PATH="/usr/bin/zsh"; elif [ -f /bin/zsh ]; then ZSH_PATH="/bin/zsh"; else ZSH_PATH=$(command -v zsh 2>/dev/null); fi; [ -n "$ZSH_PATH" ] && tmux set-option -g default-shell "$ZSH_PATH"'

# 终端类型（真彩色；Catppuccin 推荐 tmux-256color + RGB）
set -g default-terminal "tmux-256color"
set -ga terminal-features ",*:RGB"

# ============================================
# Catppuccin Mocha 主题（手动加载，见 run_once_install-tmux.sh.tmpl）
# ============================================

set -g @catppuccin_flavor 'mocha'
set -g @catppuccin_window_status_style "rounded"

# 状态栏 window 标签用 #W（window 名）；#T 是 pane 标题，Prefix+, 改名不会更新 #T
set -g @catppuccin_window_text " #W"
set -g @catppuccin_window_current_text " #W*"
set -g @catppuccin_window_number_color "#{@thm_surface_0}"
set -g @catppuccin_window_text_color "#{@thm_surface_0}"
set -g @catppuccin_window_current_number_color "#{@thm_mauve}"
set -g @catppuccin_window_current_text_color "#{@thm_mauve}"

# 必须在设置 status-left/right 之前 run（Catppuccin v2 要求）
run '~/.config/tmux/plugins/catppuccin/tmux/catppuccin.tmux'

# 状态栏：左侧 session 名 + 中间 window 标签（由主题渲染）
set -g status-left-length 100
set -g status-right-length 100
set -g status-left "#{E:@catppuccin_status_session}"
set -g status-right ""

# ============================================
# 复制模式（vi 键位，配合 tmux-yank）
# ============================================
setw -g mode-keys vi
bind -T copy-mode-vi v send-keys -X begin-selection
bind -T copy-mode-vi C-v send-keys -X rectangle-toggle

# ============================================
# TPM (Tmux Plugin Manager) 插件配置
# ============================================
# TPM 快捷键：Prefix+I 安装 / Prefix+U 更新 / Prefix+Alt+u 卸载

set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'tmux-plugins/tmux-yank'
set -g @yank_with_mouse on
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @resurrect-strategy-vim 'session'
set -g @plugin 'tmux-plugins/tmux-continuum'
set -g @continuum-restore 'on'
set -g @continuum-save-interval '15'

# 初始化 TPM（必须放在配置文件最后）
run '~/.tmux/plugins/tpm/tpm'

# ============================================
# 必须在 TPM 加载后重新设置这些选项
# ============================================

# 设置状态栏位置为顶部（覆盖主题默认设置）
set -g status-position top
{{- end -}}

