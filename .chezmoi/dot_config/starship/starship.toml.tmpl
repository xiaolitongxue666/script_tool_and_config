# ============================================
# 其他工具模块
# ============================================

# Docker 上下文模块
[docker_context]
symbol = "🐳 "
style = "bg:#d08770 fg:#2e3440"
format = "[ $symbol$context ]($style)"
disabled = false

# 时间模块
[time]
# 是否禁用（默认禁用，需要时启用）
disabled = true
# 时间格式（24小时制，时:分）
time_format = "%R"
# 样式
style = "bg:#ebcb8b fg:#2e3440"
# 格式
format = "[ $time ]($style)"

# ============================================
# 字符模块（提示符符号）
# ============================================
[character]
# 成功命令后的提示符
success_symbol = "[❯](fg:#a3be8c bold)"
# 失败命令后的提示符
error_symbol = "[❯](fg:#bf616a bold)"
# Vim 命令模式提示符
vimcmd_symbol = "[❮](fg:#ebcb8b bold)"
