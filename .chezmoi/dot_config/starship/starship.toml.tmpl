# Starship 提示符配置
# 参考: https://starship.rs/config/
# 文档: https://starship.rs/config/

# ============================================
# 全局配置
# ============================================

# 命令超时时间（毫秒）
# 如果命令执行时间超过此值，将不会显示该模块
command_timeout = 10000

# 添加提示符前的空行
add_newline = false

# ============================================
# 提示符格式
# ============================================
# 使用 Powerline 分隔符创建分段提示符
# 样式目标：用户@主机、缩略路径、Git 分支以色块串联显示
format = """
[](fg:#3b4252)\
$username\
$hostname\
[](fg:#3b4252 bg:#5e81ac)\
$directory\
[](fg:#5e81ac bg:#a3be8c)\
$git_branch\
$git_status\
[](fg:#a3be8c)\
$character\
"""

# ============================================
# 用户名模块
# ============================================
[username]
# 是否始终显示用户名（即使与当前用户相同）
show_always = true
# 普通用户样式
style_user = "bg:#3b4252 fg:#eceff4 bold"
# root 用户样式
style_root = "bg:#bf616a fg:#eceff4 bold"
# 格式
format = "[ $user]($style)"
disabled = false

# ============================================
# 主机名模块
# ============================================
[hostname]
ssh_only = false
style = "bg:#3b4252 fg:#eceff4 bold"
format = "[@$hostname ]($style)"
disabled = false

# ============================================
# 操作系统模块（默认禁用，使用用户名与主机名）
# ============================================
[os]
style = "bg:#bd93f9 fg:#282a36"
disabled = true  # 默认禁用，使用用户名模块

# ============================================
# 目录模块
# ============================================
[directory]
# 样式
style = "bg:#5e81ac fg:#eceff4 bold"
# 格式
format = "[ $path ]($style)"
# 路径截断长度（显示最后 N 个目录）
truncation_length = 2
# 截断符号
truncation_symbol = "…/"
# 在 Git 仓库中也按路径长度缩略，避免只显示仓库名
truncate_to_repo = false
# Windows Git Bash 中也使用 / 作为路径分隔符，贴近类 Unix 终端显示
use_os_path_sep = false

# 目录路径替换（使用图标简化常见目录名）
# 注意：顺序很重要，更具体的路径应该放在前面
[directory.substitutions]
"Documents" = "📄 "
"Downloads" = "⬇ "
"Music" = "🎵 "
"Pictures" = "🖼 "
"Desktop" = "🖥 "
"Code" = "💻 "
"Projects" = "📁 "

# ============================================
# Git 分支模块
# ============================================
[git_branch]
# Git 分支符号
symbol = " "
# 样式
style = "bg:#a3be8c fg:#2e3440 bold"
# 格式
format = "[ $symbol$branch ]($style)"
disabled = false

# ============================================
# Git 状态模块
# ============================================
[git_status]
# 样式（与 git_branch 相同）
style = "bg:#a3be8c fg:#2e3440 bold"
# 格式
format = "[$all_status$ahead_behind ]($style)"
disabled = false

# ============================================
# 编程语言版本模块
# ============================================

