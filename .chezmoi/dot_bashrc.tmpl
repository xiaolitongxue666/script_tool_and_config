{{- if ne .chezmoi.os "darwin" -}}
# Bash 统一配置文件
# 自动检测操作系统并加载对应配置
# 注意：macOS 使用 .bash_profile，此文件不适用于 macOS

# ============================================
# 修复 Claude Code shell snapshot 污染
# MINGW64 上 snapshot 序列化会丢失 "shopt -" 前缀
# 在 snapshot 被 source 前修复，避免 "s: command not found" 噪音
# ============================================
for __snap_fix in ~/.claude/shell-snapshots/snapshot-bash-*.sh; do
  [ -f "$__snap_fix" ] && sed -i 's/^s sourcepath/shopt -s sourcepath/' "$__snap_fix" 2>/dev/null || true
done
unset __snap_fix

# ============================================
# 系统检测
# ============================================
if [[ "$OSTYPE" == "darwin"* ]]; then
    OS="macos"
elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
    OS="linux"
elif [[ "$OSTYPE" == "msys" ]] || [[ "$OSTYPE" == "cygwin" ]]; then
    OS="windows"
else
    OS="unknown"
fi

# ============================================
# 通用配置（所有平台）
# ============================================

# ============================================
# 代理配置（统一配置，参考 Git Bash）
# ============================================
# 默认代理地址：Linux 下自动区分 WSL2 与原生（WSL2 中 127.0.0.1 无法访问宿主机，需用 /etc/resolv.conf 的 nameserver）
if [[ "$OSTYPE" == "linux-gnu"* ]]; then
    if grep -qEi "Microsoft|WSL" /proc/version 2>/dev/null || [[ -n "${WSL_DISTRO_NAME:-}" ]]; then
        _proxy_host=$(cat /etc/resolv.conf 2>/dev/null | grep nameserver | awk '{print $2}')
        PROXY_DEFAULT="http://${_proxy_host:-127.0.0.1}:7890"
    else
        PROXY_DEFAULT="http://127.0.0.1:7890"
    fi
else
    PROXY_DEFAULT="{{ env "http_proxy" | default "http://127.0.0.1:7890" }}"
fi
PROXY_URL="${PROXY:-${http_proxy:-$PROXY_DEFAULT}}"

# 代理控制别名（同时设置大小写环境变量，确保所有工具都能识别）
# h_proxy: 快速启用代理
alias h_proxy='export http_proxy='"$PROXY_URL"'; export https_proxy='"$PROXY_URL"'; export HTTP_PROXY='"$PROXY_URL"'; export HTTPS_PROXY='"$PROXY_URL"'; export all_proxy='"$PROXY_URL"'; export ALL_PROXY='"$PROXY_URL"'; echo "代理已启用: $PROXY_URL"'
# unset_h: 关闭代理（清除所有代理环境变量）
alias unset_h='unset http_proxy; unset https_proxy; unset HTTP_PROXY; unset HTTPS_PROXY; unset all_proxy; unset ALL_PROXY; echo "代理已关闭"'
# WSL 常用命名：proxy_on / proxy_off 与 h_proxy / unset_h 等价
alias proxy_on='h_proxy'
alias proxy_off='unset_h'

# net_diag: 网络诊断（出口 IP、GitHub 连通性、下载测速）
# 说明：保留 -k 以适配部分代理/证书链环境，便于快速排查网络问题
alias net_diag='echo "出口IP信息：" && curl -s -L -k ip-api.com && echo "" && echo "GitHub状态：" && curl -IsLk https://github.com | head -n 1 && echo "" && echo "测速结果：" && curl -s -L -k "https://speed.cloudflare.com/__down?bytes=10000000" -o /dev/null -w "下载速度: %{speed_download} B/s\n"'

# 默认启用代理（可选，取消注释以自动启用）
# h_proxy

# Bat instead cat
if command -v bat &> /dev/null; then
    alias cat='bat'
fi

# ============================================
# 平台特定配置
# ============================================

# macOS 特定配置
if [[ "$OS" == "macos" ]]; then
    # 添加用户私有 shell 路径
    export PATH=$PATH:/Users/liyong/Code/Tools/Shells/BashTools

    # SDKMAN（必须在文件末尾）
    export SDKMAN_DIR="/Users/liyong/.sdkman"
    [[ -s "/Users/liyong/.sdkman/bin/sdkman-init.sh" ]] && source "/Users/liyong/.sdkman/bin/sdkman-init.sh"

    # 路径配置
    export PATH="/Applications/Postgres.app/Contents/Versions/latest/bin:$PATH"
    export PATH="/Users/liyong/Library/Python/2.7/bin:$PATH"
    export PATH=$PATH':/path/to/add'
    export PATH="/usr/local/bin:$PATH"
    export PATH="/usr/local/opt/make/libexec/gnubin:$PATH"

    # GEM 配置
    export GEM_HOME=$HOME/.gem
    export GEM_PATH=$HOME/.gem

    # fnm (Fast Node Manager) - 与 dot_bash_profile 一致，保持模板语义统一
    if [ -d "{{ .chezmoi.homeDir }}/.local/share/fnm" ]; then
        export PATH="{{ .chezmoi.homeDir }}/.local/share/fnm:$PATH"
        if command -v fnm >/dev/null 2>&1; then
            eval "$(fnm env --shell=bash --use-on-cd)"
            if [ -f "$HOME/.node-version" ]; then
                NODE_VERSION=$(cat "$HOME/.node-version" 2>/dev/null | tr -d '\n\r' | sed 's/^v//')
                if [ -n "$NODE_VERSION" ]; then
                    fnm use "$NODE_VERSION" 2>/dev/null || true
                fi
            fi
        fi
    elif [ -d "{{ .chezmoi.homeDir }}/.fnm" ]; then
        export PATH="{{ .chezmoi.homeDir }}/.fnm:$PATH"
        if command -v fnm >/dev/null 2>&1; then
            eval "$(fnm env --shell=bash --use-on-cd)"
            if [ -f "$HOME/.node-version" ]; then
                NODE_VERSION=$(cat "$HOME/.node-version" 2>/dev/null | tr -d '\n\r' | sed 's/^v//')
                if [ -n "$NODE_VERSION" ]; then
                    fnm use "$NODE_VERSION" 2>/dev/null || true
                fi
            fi
        fi
    fi

    # Cargo
    if [ -f "$HOME/.cargo/env" ]; then
        . "$HOME/.cargo/env"
    fi

# Windows 特定配置（Git Bash/MSYS2）
elif [[ "$OS" == "windows" ]]; then
    # Claude Code：须用 Git for Windows 的 bin\bash.exe；勿用 msys64 的 command -v bash；usr\bin 与脏环境变量一律丢弃后按候选路径探测
    if [[ -n "${CLAUDE_CODE_GIT_BASH_PATH:-}" ]]; then
        _ccgbp_slash="${CLAUDE_CODE_GIT_BASH_PATH//\\//}"
        case "${_ccgbp_slash}" in
            */usr/bin/bash|*/usr/bin/bash.exe) unset CLAUDE_CODE_GIT_BASH_PATH ;;
        esac
        if [[ -n "${CLAUDE_CODE_GIT_BASH_PATH:-}" ]]; then
            _cc_lc="${CLAUDE_CODE_GIT_BASH_PATH,,}"
            if [[ "${_cc_lc}" == *msys64* ]] || [[ "${_cc_lc}" == *msys2* ]] || [[ "${_cc_lc}" == *cygwin* ]]; then
                unset CLAUDE_CODE_GIT_BASH_PATH
            fi
        fi
        unset _cc_lc _ccgbp_slash
    fi
    if [[ -z "${CLAUDE_CODE_GIT_BASH_PATH:-}" ]] && command -v cygpath &>/dev/null; then
        _claude_git_bash_exe=""
        while IFS= read -r _cc_cand; do
            _cc_cand="${_cc_cand//$'\r'/}"
            [[ -z "${_cc_cand}" ]] && continue
            if [[ -x "${_cc_cand}" ]]; then
                _claude_git_bash_exe="${_cc_cand}"
                break
            fi
        done <<'CC_GIT_BASH_CANDS'
/d/Program Files/Git/bin/bash.exe
/d/Program Files (x86)/Git/bin/bash.exe
/c/Program Files/Git/bin/bash.exe
/c/Program Files (x86)/Git/bin/bash.exe
CC_GIT_BASH_CANDS
        if [[ -z "${_claude_git_bash_exe}" ]] && [[ -n "${LOCALAPPDATA:-}" ]]; then
            _cc_lp="$(cygpath -u "${LOCALAPPDATA}" 2>/dev/null)/Programs/Git/bin/bash.exe"
            [[ -x "${_cc_lp}" ]] && _claude_git_bash_exe="${_cc_lp}"
            unset _cc_lp
        fi
        if [[ -n "${_claude_git_bash_exe}" ]]; then
            export CLAUDE_CODE_GIT_BASH_PATH="$(cygpath -w "${_claude_git_bash_exe}" 2>/dev/null)"
        fi
        unset _cc_cand _claude_git_bash_exe
    fi

    # History
    PROMPT_COMMAND='history -a'

    # 代理配置（Windows 使用完整配置，参考 Git Bash）
    # 注意：Windows Git Bash 的详细代理配置在 .bash_profile 中
    # 这里只设置基本变量，.bash_profile 中有完整的 curl 包装函数
    PROXY_URL="${PROXY:-{{ env "http_proxy" | default "http://127.0.0.1:7890" }}}"
    export http_proxy="$PROXY_URL"
    export https_proxy="$PROXY_URL"
    export HTTP_PROXY="$PROXY_URL"
    export HTTPS_PROXY="$PROXY_URL"
    export all_proxy="$PROXY_URL"
    export ALL_PROXY="$PROXY_URL"

    # opencode 配置（兼容官方新路径 ~/.opencode/bin 与历史路径 /c/opencode）
    if [ -d "$HOME/.opencode/bin" ] && [[ ":$PATH:" != *":$HOME/.opencode/bin:"* ]]; then
        export PATH="$HOME/.opencode/bin:$PATH"
    elif [ -d "/c/opencode" ] && [[ ":$PATH:" != *":/c/opencode:"* ]]; then
        export PATH="/c/opencode:$PATH"
    fi

    # 网络检查别名
    alias check_network='curl -IL https://www.google.com 2>/dev/null | grep -q -E "200 OK|Connection established" && echo "Network is OK" || echo "Network is down"'

    # Explorer
    alias open='explorer'

    # Docker 工作区（Windows Git Bash）
    docker() {
        (export MSYS_NO_PATHCONV=1; "docker.exe" "$@")
    }

    # Docker Compose 工作区（Windows Git Bash）
    docker-compose() {
        (export MSYS_NO_PATHCONV=1; "docker-compose.exe" "$@")
    }

    # 非登录 shell 下确保能找到 oh-my-posh/starship（与 run_on_windows/dot_bash_profile 的 PATH 一致）
    for _d in "$HOME/AppData/Local/Microsoft/WinGet/Links" "$HOME/AppData/Local/Programs/oh-my-posh"; do
        [ -d "$_d" ] && [[ ":$PATH:" != *":$_d:"* ]] && export PATH="$PATH:$_d"
    done
    unset _d

    # Windows 提示符：仅用 Oh My Posh（与 run_on_windows/dot_bash_profile 一致，避免登录/非登录显示不同）
    _omp_config="$HOME/AppData/Local/Programs/oh-my-posh/themes/montys.omp.json"
    if command -v oh-my-posh &> /dev/null; then
        if [ -f "$_omp_config" ]; then
            eval "$(oh-my-posh --init --shell bash --config "$_omp_config")"
        else
            eval "$(oh-my-posh --init --shell bash)"
        fi
    elif command -v starship &> /dev/null; then
        eval "$(starship init bash)"
    fi
    unset _omp_config

    # 打开默认路径：仅在非编辑器终端中执行，避免 Cursor/VS Code 终端被切到固定目录（保持项目根目录）
    if [ -z "${TERM_PROGRAM:-}" ]; then
        cd /d/Code 2>/dev/null || cd ~
        echo "Welcome! 😊"
    fi

# Linux 特定配置
elif [[ "$OS" == "linux" ]]; then
    # 用户本地 bin（chezmoi、uv、lazygit 等）与 cargo，与 .zprofile 对齐，确保登录/自启动后可用
    export PATH="{{ .chezmoi.homeDir }}/.local/bin:{{ .chezmoi.homeDir }}/.cargo/bin:$PATH"
    # Debian/Ubuntu: bat 包提供 batcat，fd-find 包提供 fdfind，统一为 bat/fd 命令
    if command -v batcat &>/dev/null && ! command -v bat &>/dev/null; then alias bat=batcat; fi
    if command -v fdfind &>/dev/null && ! command -v fd &>/dev/null; then alias fd=fdfind; fi
    # fnm (Fast Node Manager) - Node.js 版本管理（仅 Linux，不影响 Windows）
    # 参考: https://github.com/Schniz/fnm
    if [ -d "{{ .chezmoi.homeDir }}/.local/share/fnm" ]; then
        export PATH="{{ .chezmoi.homeDir }}/.local/share/fnm:$PATH"
        if command -v fnm >/dev/null 2>&1; then
            eval "$(fnm env --shell=bash --use-on-cd)"
            if [ -f "$HOME/.node-version" ]; then
                NODE_VERSION=$(cat "$HOME/.node-version" 2>/dev/null | tr -d '\n\r' | sed 's/^v//')
                if [ -n "$NODE_VERSION" ]; then
                    fnm use "$NODE_VERSION" 2>/dev/null || true
                fi
            fi
        fi
    elif [ -d "{{ .chezmoi.homeDir }}/.fnm" ]; then
        export PATH="{{ .chezmoi.homeDir }}/.fnm:$PATH"
        if command -v fnm >/dev/null 2>&1; then
            eval "$(fnm env --shell=bash --use-on-cd)"
            if [ -f "$HOME/.node-version" ]; then
                NODE_VERSION=$(cat "$HOME/.node-version" 2>/dev/null | tr -d '\n\r' | sed 's/^v//')
                if [ -n "$NODE_VERSION" ]; then
                    fnm use "$NODE_VERSION" 2>/dev/null || true
                fi
            fi
        fi
    fi
    # Cursor/VS Code 连接 WSL 时默认可能启动 bash；交互式下自动切到 zsh 以加载 Starship（Agent 模式保留 bash）
    if [[ -o interactive ]] && [[ -z "${CURSOR_AGENT:-}" ]] && command -v zsh &>/dev/null; then
        exec zsh
    fi
fi

# ============================================
# claude-mem 项目记忆自动检测
# 从当前目录向上查找 .claude-mem/settings.json
# 找到则使用项目级记忆，否则用全局 (~/.claude-mem)
# ============================================
claude() {
  local _cm_dir="$PWD"
  while [[ "$_cm_dir" != "/" ]]; do
    if [ -f "$_cm_dir/.claude-mem/settings.json" ]; then
      export CLAUDE_MEM_DATA_DIR="$_cm_dir/.claude-mem"
      export CLAUDE_MEM_SETTINGS_PATH="$_cm_dir/.claude-mem/settings.json"
      echo "claude-mem: using project memory at $_cm_dir/.claude-mem" >&2
      break
    fi
    _cm_dir="$(dirname "$_cm_dir")"
  done
  command claude "$@"
}
{{- end -}}
