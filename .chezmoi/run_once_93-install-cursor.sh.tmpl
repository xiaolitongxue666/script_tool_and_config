{{- if or (eq .chezmoi.os "linux") (eq .chezmoi.os "darwin") (eq .chezmoi.os "windows") -}}
#!/usr/bin/env bash

# ============================================
# Cursor 编辑器安装（chezmoi run_once_）
# 仅在有 GUI 的环境下安装（全平台，但 Linux/WSL 需检测 DISPLAY）
# ============================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="${CHEZMOI_PROJECT_ROOT:-$(cd "${SCRIPT_DIR}/../.." && pwd 2>/dev/null || echo "$HOME")}"
COMMON_INSTALL="${PROJECT_ROOT}/scripts/chezmoi/common_install.sh"

if [[ ! -f "$COMMON_INSTALL" ]]; then
    COMMON_INSTALL="$HOME/.local/share/chezmoi/scripts/chezmoi/common_install.sh"
fi

if [[ -f "$COMMON_INSTALL" ]]; then
    source "$COMMON_INSTALL"
else
    echo "[WARNING] common_install.sh not found, using basic functions"
    function setup_proxy() { :; }
    function detect_os_and_package_manager() {
        OS="$(uname -s)"
        if [[ "$OS" == "Darwin" ]]; then
            PLATFORM="darwin"; PACKAGE_MANAGER="brew"
        elif [[ "$OS" == "Linux" ]]; then
            PLATFORM="linux"
            command -v pacman &>/dev/null && PACKAGE_MANAGER="pacman"
            command -v apt-get &>/dev/null && PACKAGE_MANAGER="apt"
            command -v dnf &>/dev/null && PACKAGE_MANAGER="dnf"
        elif [[ "$OS" =~ ^(MINGW|MSYS|CYGWIN) ]]; then
            PLATFORM="windows"; PACKAGE_MANAGER="winget"
        fi
    }
fi

setup_proxy "${PROXY:-{{ env "http_proxy" | default "http://127.0.0.1:7890" }}}"
detect_os_and_package_manager || exit 1

IS_WSL=0
if [[ "$PLATFORM" == "linux" ]]; then
    grep -qEi "Microsoft|WSL" /proc/version 2>/dev/null || [[ -n "${WSL_DISTRO_NAME:-}" ]] && IS_WSL=1
fi

# ============================================
# GUI 检测：仅在有 GUI 的环境中安装 Cursor
# ============================================
has_gui() {
    case "$PLATFORM" in
        darwin|windows)
            # macOS / Windows 默认有 GUI
            return 0
            ;;
        linux)
            # Linux / WSL：需要 DISPLAY 或 WAYLAND_DISPLAY
            if [[ -n "${DISPLAY:-}" || -n "${WAYLAND_DISPLAY:-}" ]]; then
                return 0
            fi
            # WSLg 也会提供 DISPLAY
            return 1
            ;;
    esac
    return 1
}

if ! has_gui; then
    echo "[INFO] No GUI detected (Linux without DISPLAY/WAYLAND_DISPLAY), skipping Cursor install"
    exit 0
fi

echo "[INFO] GUI detected, checking Cursor..."

# 检查 Cursor 是否已安装
if command -v cursor &>/dev/null; then
    echo "[INFO] Cursor already installed: $(cursor --version 2>/dev/null | head -n1)"
    exit 0
fi

echo "[INFO] Installing Cursor..."

case "$PLATFORM" in
    darwin)
        # macOS：通过 Homebrew Cask 安装
        if [[ "$PACKAGE_MANAGER" == "brew" ]]; then
            if brew list --cask cursor &>/dev/null; then
                echo "[INFO] Cursor already installed via Homebrew"
            elif brew install --cask cursor; then
                echo "[SUCCESS] Cursor installed via Homebrew"
            else
                echo "[WARNING] Homebrew Cask install failed, please install manually from https://cursor.sh"
            fi
        else
            echo "[INFO] Please install Cursor manually from https://cursor.sh"
        fi
        ;;
    linux)
        # Linux / WSL：通过 AppImage 或直接下载
        local dest_dir="${HOME}/.local/bin"
        mkdir -p "$dest_dir"

        if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
            # Arch：从 AUR 安装 cursor-bin
            for aur in yay paru; do
                if command -v "$aur" &>/dev/null; then
                    if "$aur" -S --noconfirm cursor-bin 2>/dev/null; then
                        echo "[SUCCESS] Cursor installed via AUR"
                        exit 0
                    fi
                fi
            done
        fi

        # 通用方式：下载 AppImage
        echo "[INFO] Downloading Cursor AppImage..."
        local appimage_url="https://downloader.cursor.sh/linux/appImage/x64"
        local appimage_path="${dest_dir}/cursor.AppImage"

        if curl -fsSL "$appimage_url" -o "$appimage_path" 2>/dev/null; then
            chmod +x "$appimage_path"
            ln -sf "$appimage_path" "${dest_dir}/cursor"
            echo "[SUCCESS] Cursor AppImage installed to ${dest_dir}/cursor"
        else
            echo "[WARNING] Failed to download Cursor AppImage"
            echo "[INFO] Please install manually: https://cursor.sh"
        fi
        ;;
    windows)
        # Windows：通过 winget 安装
        if [[ "$PACKAGE_MANAGER" == "winget" ]]; then
            if winget install -e --id Cursor.Cursor --accept-source-agreements --accept-package-agreements 2>/dev/null; then
                echo "[SUCCESS] Cursor installed via winget"
            else
                echo "[WARNING] winget install failed, please install manually from https://cursor.sh"
            fi
        else
            echo "[INFO] Please install Cursor manually from https://cursor.sh"
        fi
        ;;
esac

if command -v cursor &>/dev/null; then
    echo "[SUCCESS] Cursor available: $(cursor --version 2>/dev/null | head -n1)"
else
    echo "[WARNING] Cursor may not be in PATH. If installed, add ~/.local/bin to PATH."
fi
{{- end -}}
