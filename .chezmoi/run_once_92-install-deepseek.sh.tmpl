{{- if or (eq .chezmoi.os "linux") (eq .chezmoi.os "darwin") (eq .chezmoi.os "windows") -}}
#!/usr/bin/env bash

# ============================================
# DeepSeek CLI 安装（chezmoi run_once_）
# 通过 cargo 安装 deepseek CLI（TUI 模式）
# 参考: cargo install deepseek
# ============================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="${CHEZMOI_PROJECT_ROOT:-$(cd "${SCRIPT_DIR}/../.." && pwd 2>/dev/null || echo "$HOME")}"
COMMON_INSTALL="${PROJECT_ROOT}/scripts/chezmoi/common_install.sh"

if [[ ! -f "$COMMON_INSTALL" ]]; then
    COMMON_INSTALL="$HOME/.local/share/chezmoi/scripts/chezmoi/common_install.sh"
fi

if [[ -f "$COMMON_INSTALL" ]]; then
    source "$COMMON_INSTALL"
else
    echo "[WARNING] common_install.sh not found, using basic functions"
    function setup_proxy() { :; }
    function detect_os_and_package_manager() {
        OS="$(uname -s)"
        if [[ "$OS" == "Darwin" ]]; then
            PLATFORM="darwin"; PACKAGE_MANAGER="brew"
        elif [[ "$OS" == "Linux" ]]; then
            PLATFORM="linux"
            command -v pacman &>/dev/null && PACKAGE_MANAGER="pacman"
            command -v apt-get &>/dev/null && PACKAGE_MANAGER="apt"
            command -v dnf &>/dev/null && PACKAGE_MANAGER="dnf"
        elif [[ "$OS" =~ ^(MINGW|MSYS|CYGWIN) ]]; then
            PLATFORM="windows"; PACKAGE_MANAGER="winget"
        fi
    }
fi

setup_proxy "${PROXY:-{{ env "http_proxy" | default "http://127.0.0.1:7890" }}}"
detect_os_and_package_manager || exit 1

IS_WSL=0
if [[ "$PLATFORM" == "linux" ]]; then
    grep -qEi "Microsoft|WSL" /proc/version 2>/dev/null || [[ -n "${WSL_DISTRO_NAME:-}" ]] && IS_WSL=1
fi

# 检查 deepseek 是否已安装
if command -v deepseek &>/dev/null; then
    echo "[INFO] deepseek CLI already installed: $(deepseek --version 2>/dev/null | head -n1)"
    exit 0
fi

echo "[INFO] Installing deepseek CLI via cargo..."

# 确保 cargo 已安装
if ! command -v cargo &>/dev/null; then
    echo "[INFO] cargo not found. Installing rustup first..."
    if command -v rustup &>/dev/null; then
        rustup update 2>/dev/null || true
    else
        curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
        export PATH="$HOME/.cargo/bin:$PATH"
    fi
fi

if ! command -v cargo &>/dev/null; then
    echo "[WARNING] cargo still not available after rustup install"
    echo "[INFO] You can install deepseek manually: cargo install deepseek"
    exit 0
fi

if cargo install deepseek; then
    echo "[SUCCESS] deepseek CLI installed successfully"
    echo "[INFO] Binary location: $(command -v deepseek 2>/dev/null || echo '~/.cargo/bin/deepseek')"
else
    echo "[WARNING] cargo install deepseek failed"
    echo "[INFO] You can retry manually: cargo install deepseek"
fi

exit 0
{{- end -}}
