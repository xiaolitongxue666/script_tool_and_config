# ============================================
# 修复 Claude Code shell snapshot 污染（增强版）
# MINGW64 上 snapshot 序列化存在两个 bug:
#   1. Base64 泄漏：declare -f 输出的函数体 base64 未被 eval 包裹
#   2. shopt 截断："shopt -s" 丢失前 6 字符 → "s sourcepath"
# ============================================
for __snap_fix in ~/.claude/shell-snapshots/snapshot-bash-*.sh; do
  [ -f "$__snap_fix" ] || continue
  # 清除 base64 泄漏（50+ 字符的纯 base64 行）
  if grep -qE '^[A-Za-z0-9+/=]{50,}$' "$__snap_fix" 2>/dev/null; then
    rm -f "$__snap_fix" 2>/dev/null || true
    continue
  fi
  # 修复 shopt 截断
  sed -i 's/^s sourcepath/shopt -s sourcepath/' "$__snap_fix" 2>/dev/null || true
done
unset __snap_fix

# ============================================
# 代理配置
# ============================================
PROXY_DEFAULT="http://127.0.0.1:7890"
PROXY_URL="${PROXY:-${http_proxy:-$PROXY_DEFAULT}}"

# 代理控制别名（同时设置大小写环境变量，确保所有工具都能识别）
alias h_proxy='export http_proxy='"$PROXY_URL"'; export https_proxy='"$PROXY_URL"'; export HTTP_PROXY='"$PROXY_URL"'; export HTTPS_PROXY='"$PROXY_URL"'; export all_proxy='"$PROXY_URL"'; export ALL_PROXY='"$PROXY_URL"'; echo "代理已启用: $PROXY_URL"'
alias unset_h='unset http_proxy; unset https_proxy; unset HTTP_PROXY; unset HTTPS_PROXY; unset all_proxy; unset ALL_PROXY; echo "代理已关闭"'
alias proxy_on='h_proxy'
alias proxy_off='unset_h'

# net_diag: 网络诊断（出口 IP、GitHub 连通性、下载测速）
alias net_diag='echo "出口IP信息：" && curl -s -L -k ip-api.com && echo "" && echo "GitHub状态：" && curl -IsLk https://github.com | head -n 1 && echo "" && echo "测速结果：" && curl -s -L -k "https://speed.cloudflare.com/__down?bytes=10000000" -o /dev/null -w "下载速度: %{speed_download} B/s\n"'

# 默认启用代理（可选，取消注释以自动启用）
# h_proxy

# Bat instead cat
if command -v bat &> /dev/null; then
    alias cat='bat'
fi

# ============================================
# Claude Code：Git for Windows bash.exe 探测
# 须用 Git for Windows 的 bin\bash.exe；勿用 msys64 的 command -v bash
# usr\bin 与脏环境变量一律丢弃后按候选路径探测
# ============================================
if [[ "$(uname -s)" =~ ^(MINGW|MSYS|CYGWIN) ]] && [[ -n "${CLAUDE_CODE_GIT_BASH_PATH:-}" ]]; then
    _ccgbp_slash="${CLAUDE_CODE_GIT_BASH_PATH//\\//}"
    case "${_ccgbp_slash}" in
        */usr/bin/bash|*/usr/bin/bash.exe) unset CLAUDE_CODE_GIT_BASH_PATH ;;
    esac
    if [[ -n "${CLAUDE_CODE_GIT_BASH_PATH:-}" ]]; then
        _cc_lc="${CLAUDE_CODE_GIT_BASH_PATH,,}"
        if [[ "${_cc_lc}" == *msys64* ]] || [[ "${_cc_lc}" == *msys2* ]] || [[ "${_cc_lc}" == *cygwin* ]]; then
            unset CLAUDE_CODE_GIT_BASH_PATH
        fi
    fi
    unset _cc_lc _ccgbp_slash
fi
if [[ "$(uname -s)" =~ ^(MINGW|MSYS|CYGWIN) ]] && [[ -z "${CLAUDE_CODE_GIT_BASH_PATH:-}" ]] && command -v cygpath &>/dev/null; then
    _claude_git_bash_exe=""
    while IFS= read -r _cc_cand; do
        _cc_cand="${_cc_cand//$'\r'/}"
        [[ -z "${_cc_cand}" ]] && continue
        if [[ -x "${_cc_cand}" ]]; then
            _claude_git_bash_exe="${_cc_cand}"
            break
        fi
    done <<'CC_GIT_BASH_CANDS'
/d/Program Files/Git/bin/bash.exe
/d/Program Files (x86)/Git/bin/bash.exe
/c/Program Files/Git/bin/bash.exe
/c/Program Files (x86)/Git/bin/bash.exe
CC_GIT_BASH_CANDS
    if [[ -z "${_claude_git_bash_exe}" ]] && [[ -n "${LOCALAPPDATA:-}" ]]; then
        _cc_lp="$(cygpath -u "${LOCALAPPDATA}" 2>/dev/null)/Programs/Git/bin/bash.exe"
        [[ -x "${_cc_lp}" ]] && _claude_git_bash_exe="${_cc_lp}"
        unset _cc_lp
    fi
    if [[ -n "${_claude_git_bash_exe}" ]]; then
        export CLAUDE_CODE_GIT_BASH_PATH="$(cygpath -w "${_claude_git_bash_exe}" 2>/dev/null)"
    fi
    unset _cc_cand _claude_git_bash_exe
fi

# ============================================
# HOME 与 Windows 用户目录对齐
# 避免仅开 Bash 时落在 /home/<user>
# ============================================
if [[ "$(uname -s)" =~ ^(MINGW|MSYS|CYGWIN) ]] && command -v cygpath &>/dev/null && [[ -n "${USERPROFILE:-}" ]]; then
    _dotbash_win_home="$(cygpath -u "${USERPROFILE}")"
    if [[ -n "${_dotbash_win_home}" && "${HOME}" != "${_dotbash_win_home}" ]]; then
        export HOME="${_dotbash_win_home}"
    fi
    unset _dotbash_win_home
fi

# ============================================
