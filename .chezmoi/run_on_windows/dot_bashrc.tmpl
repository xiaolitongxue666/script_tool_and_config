# ============================================
# HOME 与 Windows 用户目录对齐（与仓库 install.sh 策略一致，避免仅开 Bash 时落在 /home/<user>）
# ============================================
if [[ "$(uname -s)" =~ ^(MINGW|MSYS|CYGWIN) ]] && command -v cygpath &>/dev/null && [[ -n "${USERPROFILE:-}" ]]; then
    _dotbash_win_home="$(cygpath -u "${USERPROFILE}")"
    if [[ -n "${_dotbash_win_home}" && "${HOME}" != "${_dotbash_win_home}" ]]; then
        export HOME="${_dotbash_win_home}"
    fi
    unset _dotbash_win_home
fi

# ============================================
# XDG 环境变量修复（Windows）
# ============================================
# 修复 XDG 路径中的引号问题
export XDG_DATA_HOME='C:\Users\Administrator\.local\share'
export XDG_STATE_HOME='C:\Users\Administrator\.local\state'
export XDG_CACHE_HOME='C:\Users\Administrator\.local\cache'

# ============================================
# inshellisense 按键绑定
# ============================================
# 如果已安装 inshellisense，加载按键绑定
if [ -f ~/.inshellisense/key-bindings.bash ]; then
    source ~/.inshellisense/key-bindings.bash
fi
