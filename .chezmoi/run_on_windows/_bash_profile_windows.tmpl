# Git Bash 配置文件
# 仅适用于 Windows Git Bash 环境
# 参考: https://git-scm.com/docs/git-bash

# ============================================
# 系统检测
# ============================================
# 确保仅在 Git Bash 环境中加载此配置
if [[ ! "$OSTYPE" =~ ^(msys|mingw|cygwin) ]]; then
    return 0
fi

# ============================================
# 登录 shell 工具 PATH（须在 source .bashrc 之前，以便 Starship 可初始化）
# ============================================
for _d in \
    "$HOME/.local/bin" \
    "$HOME/AppData/Local/Microsoft/WinGet/Links" \
    "/c/Program Files/starship/bin" \
    "/d/Program Files/starship/bin" \
    "$HOME/AppData/Local/Programs/oh-my-posh"; do
    [ -d "$_d" ] && [[ ":$PATH:" != *":$_d:"* ]] && export PATH="$PATH:$_d"
done
unset _d

# ============================================
# 加载 .bashrc（提示符 Starship/OMP 在 bashrc 中初始化）
# ============================================
if [ -f ~/.bashrc ]; then
    source ~/.bashrc
fi

# ============================================
# PATH 配置（统一管理，避免重复）
# ============================================
# 收集所有需要添加到 PATH 的目录
PATH_DIRS=()

# MSYS2 zsh 支持（如果已安装）
for msys2_bin in \
    "/c/msys64/usr/bin" \
    "/d/msys64/usr/bin" \
    "/c/Program Files/msys64/usr/bin" \
    "/d/Program Files/msys64/usr/bin" \
    "/c/Program Files (x86)/msys64/usr/bin" \
    "/d/Program Files (x86)/msys64/usr/bin"; do
    if [ -d "$msys2_bin" ] && [ -f "$msys2_bin/zsh.exe" ]; then
        PATH_DIRS+=("$msys2_bin")
        break
    fi
done

# Python 环境（uv）
[ -d "$HOME/.local/bin" ] && PATH_DIRS+=("$HOME/.local/bin")
for _uv_py in "$HOME"/AppData/Roaming/uv/python/cpython-*-windows-x86_64-none; do
    [ -d "$_uv_py" ] && PATH_DIRS+=("$_uv_py") && break
done
unset _uv_py

# btop4win（如果已安装）
if [ -d "/c/Program Files/btop4win" ]; then
    PATH_DIRS+=("/c/Program Files/btop4win")
fi

# bun（如果已安装）
[ -d "$HOME/.bun/bin" ] && PATH_DIRS+=("$HOME/.bun/bin")

# 构建新的 PATH：先添加自定义路径，然后保留系统原有 PATH
# 去重处理：只添加不存在的路径
NEW_PATH=""
for dir in "${PATH_DIRS[@]}"; do
    if [ -d "$dir" ] && [[ ":$NEW_PATH:" != *":$dir:"* ]]; then
        if [ -z "$NEW_PATH" ]; then
            NEW_PATH="$dir"
        else
            NEW_PATH="$NEW_PATH:$dir"
        fi
    fi
done

# 将自定义路径添加到系统 PATH 前面，保留系统原有 PATH
if [ -n "$NEW_PATH" ]; then
    export PATH="$NEW_PATH:$PATH"
fi

# ============================================
# 历史记录配置
# ============================================
# 不在此处设置 PROMPT_COMMAND：.bashrc 中已配置 history -a，并由 starship init 链式挂载；
# 若在此覆盖会冲掉 Starship，导致回退为 Git Bash 默认 PS1。

# 历史记录设置
export HISTSIZE=10000
export HISTFILESIZE=20000
export HISTCONTROL=ignoreboth:erasedups
shopt -s histappend

# ============================================
# 代理配置（统一配置，使用模板变量）
# ============================================
# 默认代理地址（从环境变量 PROXY 读取，默认为 http://127.0.0.1:7890）
PROXY_URL="${PROXY:-http://127.0.0.1:7890}"

# 默认代理设置（自动启用）
# 同时设置大小写环境变量，确保不同工具都能识别
export http_proxy="$PROXY_URL"
export https_proxy="$PROXY_URL"
export HTTP_PROXY="$PROXY_URL"
export HTTPS_PROXY="$PROXY_URL"
export all_proxy="$PROXY_URL"
export ALL_PROXY="$PROXY_URL"

# 代理控制别名
# h_proxy: 快速启用代理（同时设置大小写环境变量）
alias h_proxy='export http_proxy='"$PROXY_URL"'; export https_proxy='"$PROXY_URL"'; export HTTP_PROXY='"$PROXY_URL"'; export HTTPS_PROXY='"$PROXY_URL"'; export all_proxy='"$PROXY_URL"'; export ALL_PROXY='"$PROXY_URL"'; echo "代理已启用: $PROXY_URL"'
# unset_h: 关闭代理（清除所有代理环境变量）
alias unset_h='unset http_proxy; unset https_proxy; unset HTTP_PROXY; unset HTTPS_PROXY; unset all_proxy; unset ALL_PROXY; echo "代理已关闭"'

# curl 包装函数（确保代理生效）
# Windows Git Bash 中的 curl 可能不会自动识别环境变量，需要显式使用 --proxy
curl() {
    local proxy_url=""
    # 检查代理环境变量（优先使用小写，然后大写）
    if [ -n "$http_proxy" ]; then
        proxy_url="$http_proxy"
    elif [ -n "$HTTP_PROXY" ]; then
        proxy_url="$HTTP_PROXY"
    elif [ -n "$all_proxy" ]; then
        proxy_url="$all_proxy"
    elif [ -n "$ALL_PROXY" ]; then
        proxy_url="$ALL_PROXY"
    elif [ -n "$PROXY_URL" ]; then
        proxy_url="$PROXY_URL"
    fi

    # 如果设置了代理且没有显式指定 --proxy 或 --noproxy，则自动添加 --proxy
    if [ -n "$proxy_url" ]; then
        # 检查参数中是否已有 --proxy 或 --noproxy
        local has_proxy_flag=false
        local has_noproxy_flag=false
        for arg in "$@"; do
            if [[ "$arg" == --proxy* ]] || [[ "$arg" == --proxy=* ]]; then
                has_proxy_flag=true
                break
            fi
            if [[ "$arg" == --noproxy* ]]; then
                has_noproxy_flag=true
                break
            fi
        done

        # 如果没有代理标志且没有禁用代理标志，则添加 --proxy
        if [ "$has_proxy_flag" = false ] && [ "$has_noproxy_flag" = false ]; then
            command curl --proxy "$proxy_url" "$@"
            return $?
        fi
    fi

    # 如果没有代理或已有代理标志，直接调用原始 curl
    command curl "$@"
}

