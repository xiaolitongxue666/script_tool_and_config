{{- if or (eq .chezmoi.os "linux") (eq .chezmoi.os "darwin") (eq .chezmoi.os "windows") -}}
{{/* chezmoi:template:line-endings=lf */}}
#!/usr/bin/env bash

# ============================================
# OpenAI Codex CLI 安装（chezmoi run_once_）
# 必须排在 run_once_00-install-version-managers 之后（字母序），以便 fnm/node 已就绪
# 仅安装二进制；~/.codex/settings.json 由 agent-config apply-config 管理
# 参考: npm install -g @openai/codex
# ============================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="${CHEZMOI_PROJECT_ROOT:-$(cd "${SCRIPT_DIR}/../.." && pwd 2>/dev/null || echo "$HOME")}"
COMMON_INSTALL="${PROJECT_ROOT}/scripts/chezmoi/common_install.sh"

if [[ ! -f "$COMMON_INSTALL" ]]; then
    COMMON_INSTALL="$HOME/.local/share/chezmoi/scripts/chezmoi/common_install.sh"
fi

if [[ -f "$COMMON_INSTALL" ]]; then
    # shellcheck disable=SC1090
    source "$COMMON_INSTALL"
else
    echo "[WARNING] common_install.sh not found, using basic functions" >&2
    function setup_proxy() { :; }
    function detect_os_and_package_manager() {
        OS="$(uname -s)"
        if [[ "$OS" == "Darwin" ]]; then
            PLATFORM="macos"
            PACKAGE_MANAGER="brew"
        elif [[ "$OS" == "Linux" ]]; then
            PLATFORM="linux"
            if command -v pacman &> /dev/null; then
                PACKAGE_MANAGER="pacman"
            elif command -v apt-get &> /dev/null; then
                PACKAGE_MANAGER="apt"
            elif command -v dnf &> /dev/null; then
                PACKAGE_MANAGER="dnf"
            elif command -v yum &> /dev/null; then
                PACKAGE_MANAGER="yum"
            fi
        elif [[ "$OS" =~ ^(MINGW|MSYS|CYGWIN) ]]; then
            PLATFORM="windows"
            if command -v winget &> /dev/null; then
                PACKAGE_MANAGER="winget"
            elif command -v pacman.exe &> /dev/null; then
                PACKAGE_MANAGER="pacman"
            fi
        fi
    }
fi

setup_proxy "${PROXY:-{{ env "http_proxy" | default "http://127.0.0.1:7890" }}}"

detect_os_and_package_manager || exit 1

IS_WSL=0
if [[ "${PLATFORM:-}" == "linux" ]]; then
    if grep -qEi "Microsoft|WSL" /proc/version 2>/dev/null || [[ -n "${WSL_DISTRO_NAME:-}" ]]; then
        IS_WSL=1
    fi
fi

if [[ "${PLATFORM:-}" == "darwin" ]]; then
    echo "[INFO] Environment: macOS (brew)"
elif [[ "${PLATFORM:-}" == "windows" ]]; then
    echo "[INFO] Environment: Windows (${PACKAGE_MANAGER:-unknown})"
elif [[ "${PLATFORM:-}" == "linux" ]]; then
    if [[ "$IS_WSL" -eq 1 ]]; then
        echo "[INFO] Environment: Linux (WSL, ${PACKAGE_MANAGER:-unknown})"
    else
        echo "[INFO] Environment: Linux (native, ${PACKAGE_MANAGER:-unknown})"
    fi
fi

export PATH="${HOME}/.local/share/fnm:${HOME}/.local/bin:${PATH}"

if command -v fnm &>/dev/null; then
    eval "$(fnm env 2>/dev/null)" || true
fi

if command -v codex &>/dev/null; then
    if codex --version &>/dev/null; then
        echo "[INFO] Codex CLI already installed: $(codex --version 2>/dev/null | head -n1)"
        exit 0
    fi
fi

if ! command -v fnm &>/dev/null; then
    echo "[ERROR] fnm not found. Ensure run_once_00-install-version-managers succeeded before apply."
    exit 1
fi

if ! command -v node &>/dev/null; then
    echo "[INFO] node not found, installing Node.js LTS via fnm..."
    if ! fnm install lts/* 2>&1; then
        echo "[ERROR] fnm failed to install Node.js. Check network or proxy."
        exit 1
    fi
    eval "$(fnm env 2>/dev/null)" || true
    if ! fnm use lts/* 2>/dev/null; then
        fnm use default 2>/dev/null || true
    fi
    hash -r 2>/dev/null || true
fi

if ! command -v node &>/dev/null; then
    echo "[ERROR] node still unavailable. Check fnm and PATH."
    exit 1
fi

if ! command -v npm &>/dev/null; then
    echo "[ERROR] npm unavailable (node present but npm missing)."
    exit 1
fi

echo "[INFO] Installing @openai/codex globally via npm..."
if npm install -g @openai/codex; then
    hash -r 2>/dev/null || true
    if command -v codex &>/dev/null && codex --version &>/dev/null; then
        echo "[SUCCESS] Codex CLI available: $(codex --version 2>/dev/null | head -n1)"
    else
        echo "[WARNING] npm install finished but codex not on PATH; try: npm install -g @openai/codex"
    fi
else
    echo "[WARNING] npm global install of @openai/codex failed; retry manually: npm install -g @openai/codex"
fi

exit 0
{{- end -}}
